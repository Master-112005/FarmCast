# Keep versioned model releases trackable; ignore runtime staging/production copies.
farmcast-ml/models/*/staging/*
farmcast-ml/models/*/production/*
!farmcast-ml/models/*/staging/.gitkeep
!farmcast-ml/models/*/production/.gitkeep

